rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidSpark(data) {
      return data.keys().hasAll(['title', 'url', 'thumbnail', 'genre', 'rating', 'type', 'createdAt']) &&
             data.keys().size() == 7 &&
             data.title is string && data.title.size() <= 200 &&
             data.url is string && data.url.size() <= 1000 &&
             data.thumbnail is string && data.thumbnail.size() <= 1000 &&
             data.genre is string && data.genre.size() <= 50 &&
             data.rating is number && data.rating >= 0 && data.rating <= 10 &&
             data.type is string &&
             data.createdAt is string;
    }

    match /sparks/{sparkId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidSpark(incoming()) && isValidId(sparkId);
      allow update: if isSignedIn() && isValidSpark(incoming()) && 
                    incoming().diff(resource.data).affectedKeys().hasOnly(['title', 'url', 'thumbnail', 'genre', 'rating', 'type']);
      allow delete: if isSignedIn();
    }

    match /news/{newsId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(newsId);
      allow update: if isSignedIn() && isValidId(newsId);
      allow delete: if isSignedIn();
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
